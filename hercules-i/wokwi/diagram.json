  "connections": [
    ["esp:TX0", "$serialMonitor:RX", "", []],
    ["esp:RX0", "$serialMonitor:TX", "", []],
    ["esp:D26",  "motor:A-",  "green",  []],
    ["esp:D27",  "motor:A+",  "green",  []],
    ["esp:D14",  "motor:B-",  "green",  []],
    ["esp:D12",  "motor:B+",  "green",  []],
    ["esp:D13",  "servo:PWM",   "purple", []],
