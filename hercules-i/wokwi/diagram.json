{
  "version": 1,
  "author": "Equipe A2 - IPE I / IME 2026.1",
  "editor": "wokwi",

  "$notes": [
    "Simulacao logica do Hercules I com dois motores 28BYJ-48.",
    "No hardware real, cada motor deve passar por um driver ULN2003.",
    "O Wokwi mostra os quatro fios de controle diretamente no motor para validar estados e passos."
  ],

  "parts": [
    {
      "type": "wokwi-esp32-devkit-v1",
      "id": "esp",
      "top": 150,
      "left": 360,
      "attrs": { "label": "ESP32 DevKit V1" }
    },
    {
      "type": "wokwi-stepper-motor",
      "id": "motor_t",
      "top": 20,
      "left": 20,
      "attrs": {
        "display": "steps",
        "arrow": "CCW",
        "label": "28BYJ-48 - tensionamento"
      }
    },
    {
      "type": "wokwi-stepper-motor",
      "id": "motor_d",
      "top": 320,
      "left": 20,
      "attrs": {
        "display": "steps",
        "arrow": "CW",
        "label": "28BYJ-48 - disparo"
      }
    },
    {
      "type": "wokwi-led",
      "id": "led_status",
      "top": 260,
      "left": 700,
      "attrs": {
        "color": "yellow",
        "label": "LED status - GPIO 2"
      }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_led",
      "top": 310,
      "left": 670,
      "attrs": { "value": "220", "label": "220 ohm" }
    }
  ],

  "connections": [
    ["esp:TX0", "$serialMonitor:RX", "", []],
    ["esp:RX0", "$serialMonitor:TX", "", []],

    ["esp:D26", "motor_t:A+", "blue", []],
    ["esp:D27", "motor_t:A-", "green", []],
    ["esp:D14", "motor_t:B+", "orange", []],
    ["esp:D25", "motor_t:B-", "purple", []],

    ["esp:D18", "motor_d:A+", "blue", []],
    ["esp:D19", "motor_d:A-", "green", []],
    ["esp:D21", "motor_d:B+", "orange", []],
    ["esp:D22", "motor_d:B-", "purple", []],

    ["esp:D2", "r_led:1", "yellow", []],
    ["r_led:2", "led_status:A", "yellow", []],
    ["led_status:K", "esp:GND", "black", []]
  ],

  "serialMonitor": {
    "display": "terminal",
    "newline": "lf",
    "convertEol": true
  }
}
